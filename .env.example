# Repo checkout root: source tree and application files.
# Point tools and deploys at this path on the host that runs the app.
INSTALL_SOURCE_DIR=/opt/hidden

# Host path for durable app data (flags, layout anchors).
# Stable filenames under this tree.
INSTALL_STATE_DIR=/var/lib/hidden

# Directory containing application runtime secrets.
# Used to locate gocryptfs passphrase and internal key files.
INSTALL_SECRETS_DIR=/media/secrets

# Directory containing application extensions.
# Each subdirectory is treated as a loadable extension module.
INSTALL_EXTENSIONS_DIR=/opt/hidden/extensions

# Logging severity threshold for the application.
# Values: DEBUG, INFO, WARNING, ERROR, CRITICAL.
LOG_LEVEL=INFO

# Log message format used by the Python logging system.
# Defines which fields appear in each log line.
LOG_FORMAT="%(asctime)s %(levelname)s %(name)s:%(lineno)d request_uuid=%(request_uuid)s %(message)s"

# Interval (seconds) between watchdog checks of the gocryptfs mount state.
# The watchdog unmounts the encrypted volume when secrets disappear or the
# application process stops. Must be <= GOCRYPTFS_WATCHDOG_LIVENESS_SECONDS.
GOCRYPTFS_WATCHDOG_INTERVAL_SECONDS=60

# Liveness threshold (seconds) based on the last heartbeat timestamp.
# Must be >= GOCRYPTFS_WATCHDOG_INTERVAL_SECONDS to avoid false negatives
# in /init/state.
GOCRYPTFS_WATCHDOG_LIVENESS_SECONDS=120

# SQLite journaling mode used by the database engine.
# Must be DELETE (rollback journal) — WAL is incompatible with gocryptfs:
# WAL creates a shared-memory index (.sqlite-shm) whose read-modify-write
# cycle through the FUSE encryption layer is not atomic, which causes
# database corruption under concurrent access (aiosqlite runs SQLite in a
# separate thread alongside the asyncio event loop).
SQLITE_JOURNAL_MODE=DELETE

# SQLite synchronization level controlling write durability.
# Must be FULL on a FUSE filesystem: NORMAL skips fsync, leaving writes
# buffered in the FUSE layer; an abrupt container stop before the buffer
# is flushed can corrupt the database.
SQLITE_SYNCHRONOUS=FULL

# Maximum time in milliseconds SQLite waits on database locks.
# Helps avoid transient "database is locked" errors.
SQLITE_BUSY_TIMEOUT=10000

# Location used for SQLite temporary tables and indices.
# MEMORY stores temporary data in RAM for better performance.
SQLITE_TEMP_STORE=MEMORY

# Network address where the Uvicorn HTTP server binds.
# 0.0.0.0 allows connections from any interface.
UVICORN_HOST=0.0.0.0

# TCP port where the Uvicorn HTTP server listens.
# Incoming HTTP requests to the application use this port.
UVICORN_PORT=80

# URL prefix applied to all API routes.
# Used for API versioning.
API_PREFIX=/api/v1

# Authentication token lifetime in seconds (12 hours by default).
# Applied when issuing JWTs; defines the exp claim duration.
AUTH_TOKEN_TTL_SECONDS=43200

# Allow issuing authentication tokens without expiration (1 to enable,
# 0 to disable). When enabled, clients may request a token without exp.
AUTH_ALLOW_PERMANENT_TOKENS=0

# Maximum size of the in-memory thumbnail cache in bytes (default 50 MB).
# Cached entries are served without reading from the encrypted filesystem.
# Set to 0 to disable caching entirely.
LRU_CACHE_MAX_BYTES=52428800

# Comma-separated list of allowed CORS origins.
# Matching origins receive Access-Control-Allow-Origin headers.
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Browser cache lifetime (in seconds) for CORS preflight (OPTIONS)
# responses. Defaults to 24 hours. Set to 0 to disable preflight caching.
CORS_MAX_AGE_SECONDS=86400

# Comma-separated list of enabled extensions.
# Only listed extensions are loaded by the application.
ENABLED_EXTENSIONS=example_extension
